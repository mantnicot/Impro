NEXT_PUBLIC_UNSPLASH_ACCESS_KEY=your_unsplash_access_key
NEXT_PUBLIC_PIXABAY_API_KEY=your_pixabay_api_key

# Supabase (votación multi-usuario)
# Usa claves LEGACY (JWT que empiezan con eyJ...) desde Supabase → Settings → API → Legacy anon, service_role
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your_legacy_anon_key
# Opcional en Vercel: legacy service_role (eyJ...). NO uses sb_secret_* aquí.
SUPABASE_SERVICE_ROLE_KEY=eyJ...your_legacy_service_role_key

# Código maestro para crear sesiones y panel admin (solo tú)
TAVA_MASTER_ADMIN_CODE=9804
